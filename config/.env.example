# Конфигурация решения хакатона «Цифровое здоровье»
# Скопируйте в корень проекта: cp config/.env.example .env
# НЕ коммитьте .env в git!

# --- Общее ---
APP_NAME=team-solution
TRACK=1
# 1 = Виртуальная гистотопограмма
# 2 = Прогноз заболеваемости и выживаемости
# 3 = AI-ассистент для научных исследований
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Пути к данным ---
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/
MODEL_SAVE_PATH=models/

# --- Трек 1: гистотопограмма ---
# MRXS_DATA_DIR=data/raw/mrxs/
# OUTPUT_IMAGE_PATH=data/processed/reconstruction.tif
# MRXS_TILE_SIZE=2048

# --- Трек 2: прогноз ---
# REGISTRY_CSV=data/raw/registry.csv
# TARGET_COLUMN=survival_months
# RANDOM_SEED=42
# TRAIN_TEST_SPLIT=0.8

# --- Трек 3: AI-ассистент ---
# LLM_PROVIDER=yandexgpt
# YANDEX_API_KEY=your_key_here
# YANDEX_FOLDER_ID=your_folder_id
# OPENAI_API_KEY=your_key_here
# VECTOR_STORE_PATH=data/processed/vector_index/
# EMBEDDING_MODEL=text-embedding-3-small

# --- API / демо (опционально) ---
# API_HOST=0.0.0.0
# API_PORT=8000
